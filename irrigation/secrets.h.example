#pragma once
// =============================================================================
// secrets.h.example — template for Big Drippa credentials.
//
// HOW TO USE:
//   1. Copy this file to "secrets.h" (same folder).
//   2. Fill in your values.
//   3. secrets.h is gitignored — never commit real credentials.
// =============================================================================

// ---- WiFi -------------------------------------------------------------------
#define WIFI_SSID      "your-wifi-name"
#define WIFI_PASSWORD  "your-wifi-password"

// ---- Firebase Realtime Database ---------------------------------------------
// The ESP32 authenticates as a "device account" (Email/Password) that you create
// manually in Firebase Console → Authentication → Users. This is NOT your
// personal Google account — it is a dedicated service identity for the device.
// The web app uses Google Sign-In separately.
#define FIREBASE_API_KEY        "your-web-api-key"
#define FIREBASE_DATABASE_URL   "https://your-project-default-rtdb.firebaseio.com/"
#define FIREBASE_USER_EMAIL     "device-account@your-project.firebaseapp.com"
#define FIREBASE_USER_PASSWORD  "device-account-password"
